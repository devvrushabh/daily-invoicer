# ApexInvoice - Environment Configuration Template
# Copy this file to .env and populate with your live credentials when going live.

# Application Server Settings
PORT=8080
NODE_ENV=development

# Stripe Credentials
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Credentials
PAYPAL_CLIENT_ID=AT...
PAYPAL_CLIENT_SECRET=EG...
PAYPAL_MODE=sandbox # sandbox or live

# Razorpay Credentials (India / International)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Firebase Credentials (Optional Cloud Sync)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-app-id

# EmailJS / SMTP Mailer Settings (For automated client email receipts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
